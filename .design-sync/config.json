{
  "projectId": "6c0deab6-c6d9-4f4f-8e69-911d42f43393",
  "pkg": "me",
  "globalName": "MeDS",
  "shape": "package",
  "buildCmd": "npm run build:lib",
  "srcDir": "src",
  "tsconfig": "./tsconfig.json",
  "cssEntry": "./dist-lib/style.css",
  "componentSrcMap": {
    "Layout": "src/components/Layout.tsx",
    "Header": "src/components/Header.tsx",
    "Footer": "src/components/Footer.tsx",
    "Nav": "src/components/Nav.tsx",
    "ColorBar": "src/components/ColorBar.tsx",
    "SectionHeader": "src/components/SectionHeader.tsx",
    "NutshellCard": "src/components/NutshellCard.tsx",
    "GithubIcon": "src/components/icons.tsx",
    "LinkedinIcon": "src/components/icons.tsx",
    "ArrowUpRightIcon": "src/components/icons.tsx",
    "GridBackground": "src/components/GridBackground.tsx"
  },
  "runtimeFontPrefixes": ["Archivo", "Plus Jakarta Sans"],
  "extraEntries": ["react-router-dom"],
  "readmeHeader": ".design-sync/conventions.md",
  "overrides": {
    "ColorBar": {"cardMode": "column"},
    "Footer": {"cardMode": "single", "primaryStory": "Default"},
    "Header": {"cardMode": "single", "primaryStory": "Default"},
    "Layout": {"cardMode": "single", "primaryStory": "ComConteudo"},
    "GridBackground": {"cardMode": "column"}
  }
}
